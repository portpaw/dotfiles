[user]
  name = Jon Mooring
  email = jonmooring@gmail.com
[core]
  excludesfile = $HOME/.gitignore_global
  quotepath = false
  editor = code -w
[alias]
  ci = commit
  dc = diff --cached
  df = diff
  head = show HEAD
  glog = log --decorate --graph --all
  slog = log --pretty=oneline
  sglog = log --decorate --graph --all --pretty=oneline
  st = status
  rh = reset --hard
[color]
  ui = auto
[push]
  default = upstream
[filter "lfs"]
  clean = git-lfs clean %f
  smudge = git-lfs smudge %f
  required = true
