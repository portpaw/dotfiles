[user]
        name = Jon Mooring
        email = jonmooring@gmail.com
[core]
        excludesfile = ~/.gitignore_global
        quotepath = false
[alias]
        ci = commit
        dc = diff --cached
        df = diff
        head = show HEAD
        glog = log --decorate --graph --all
        slog = log --pretty=oneline
        sglog = log --decorate --graph --all --pretty=oneline
        st = status
[color]
        ui = auto
[push]
        default = upstream
